		"vue": "catalog:",
		"vue-router": "catalog:"
	},
	"devDependencies": {
		"@rushstack/eslint-patch": "catalog:",
		"@vitejs/plugin-vue": "catalog:",
		"@vue/eslint-config-prettier": "catalog:",
		"eslint": "catalog:",
		"eslint-plugin-vue": "catalog:",
